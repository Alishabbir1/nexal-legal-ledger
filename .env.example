# Nexal Legal Ledger — environment variables (VPS)
#
# Copy to .env or set in /etc/systemd/system/nexal-ledger.service

NEXAL_DATA_DIR=/var/lib/nexal-legal

# Set on VPS production — refuses startup with known dev secrets when true
NEXAL_PRODUCTION=true

# Must match the live Portal URL (Vercel). Do NOT use https://nexallegal.co.uk
NEXAL_PORTAL_URL=https://nexal-legal.vercel.app

SSO_SECRET_KEY=
FLASK_SECRET_KEY=
NEXAL_OPS_SECRET=
